# Supabase — required for backend (database, auth, edge functions)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-supabase-project-id

# Wearable & Evidence API (Cloud Run) — optional, falls back to demo data
VITE_WEARABLE_API_URL=https://your-cloud-run-url.run.app

# The following secrets must be set in Supabase Edge Function secrets (not here):
# PAID_API_KEY       — Paid.ai API key for usage-based billing signals
# GEMINI_API_KEY     — Google Gemini for AI-generated plan explanations
# ML_ENDPOINT_URL    — ML model endpoint for injury risk prediction
